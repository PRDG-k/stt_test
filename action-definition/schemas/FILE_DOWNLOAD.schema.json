{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FILE_DOWNLOAD",
  "type": "object",
  "required": ["action", "fileType", "params"],
  "properties": {
    "action": {
      "type": "string",
      "const": "FILE_DOWNLOAD"
    },
    "fileType": {
      "type": "string",
      "enum": ["xlsx", "csv", "pdf"],
      "description": "다운로드 파일 형식"
    },
    "params": {
      "type": "object",
      "required": ["reportName", "start", "end", "downloadUrl"],
      "properties": {
        "reportName": {
          "type": "string",
          "description": "리포트 이름"
        },
        "start": {
          "type": "string",
          "description": "조회 시작 일시 (형식: YYYY-mm-dd hh:MM)"
        },
        "end": {
          "type": "string",
          "description": "조회 종료 일시 (형식: YYYY-mm-dd hh:MM)"
        },
        "downloadUrl": {
          "type": "string",
          "description": "다운로드 URL"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}